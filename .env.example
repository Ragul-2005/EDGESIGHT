# Google Gemini API Key (for voice chatbot and AI features)
# Get it from: https://cloud.google.com/docs/authentication/getting-started
GEMINI_API_KEY=your-gemini-api-key-here

# Google Maps API Key (for location tracking and navigation)
# Get it from: https://cloud.google.com/maps-platform/
# Required APIs: Google Maps JavaScript API, Places API, Directions API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
